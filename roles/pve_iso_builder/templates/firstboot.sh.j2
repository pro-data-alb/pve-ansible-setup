#!/usr/bin/env bash
# =============================================================================
# Proxmox VE First-Boot Hook
# Systemd-Service: proxmox-first-boot.service
# Log:             /var/log/pve-firstboot.log
#
# Phasen (Reihenfolge ist zwingend - APT braucht Netzwerk!):
#   1. APT-Repo-Dateien umschreiben       (nur Disk-Ops, kein Netz noetig)
#   2. System haerten: SSH + sysctl       (nur Disk-Ops, kein Netz noetig)
#   3. Management-Bond (bond0 + vmbr0)    (Netzwerk HERSTELLEN)
#      - MACs aus pve_nic_aliases[role=bond0] via /sys/class/net aufloesen
#      - udev-Regeln fuer stabile Interfacenamen schreiben
#      - bond0 (LACP fast) + vmbr0 (statische Mgmt-IP) aufbauen
#      - DHCP-Interface deaktivieren
#      => Node erreichbar auf {{ pve_node_ip }}
#   4. APT update + Pakete installieren   (Netz MUSS vorher stehen!)
#   5. Post-Network: lldpd, NTP, Subscription-Popup
#
# Render-Zeit vs. Laufzeit:
#   {# Jinja2: {{ var }} / {% if %} #}  -> wird von Ansible beim ISO-Build aufgeloest
#   ${ }   / $(  )                      -> Bash, wird auf dem Node zur Laufzeit ausgefuehrt
#
# Fehlerbehandlung Netzwerk:
#   Bond/Bridge-Fehler brechen das Script NICHT ab (nur WARNUNG im Log).
#   Phase 4+5 laufen immer durch - APT kann ggf. noch ueber DHCP-Interface arbeiten.
#   Konfiguration wird trotzdem geschrieben; nach manuellem Fix genuegt: ifup bond0 vmbr0
# =============================================================================
{% raw %}
set -euo pipefail
exec > >(tee -a /var/log/pve-firstboot.log) 2>&1

log()  { echo "[firstboot $(date '+%H:%M:%S')] $*"; }
warn() { echo "[firstboot $(date '+%H:%M:%S')] WARNUNG: $*"; }
fail() { echo "[firstboot $(date '+%H:%M:%S')] FEHLER: $*" >&2; exit 1; }

log "=== Start (ordering: ${1:-unknown}) ==="

wait_for_apt() {
    local retries=30
    while flock -n /var/lib/dpkg/lock-frontend true 2>/dev/null; do
        sleep 0
        break
    done
    while ! flock -n /var/lib/dpkg/lock-frontend true 2>/dev/null; do
        (( retries-- <= 0 )) && fail "APT-Lock Timeout nach 90s"
        log "  APT-Lock belegt, warte 3s (${retries} Versuche verbleibend)..."
        sleep 3
    done
}
{% endraw %}

# =============================================================================
# Phase 1: APT-Repo-Dateien umschreiben (nur Disk - kein Netzwerk noetig)
# =============================================================================
{% if not pve_use_subscription %}
{% raw %}
log "Phase 1: Enterprise-Repos deaktivieren, no-subscription aktivieren"
for f in /etc/apt/sources.list.d/pve-enterprise.list \
          /etc/apt/sources.list.d/ceph.list; do
    [ -f "$f" ] && sed -i 's|^deb |# deb |g' "$f" && log "  deaktiviert: $f"
done
cat > /etc/apt/sources.list.d/pve-no-subscription.list <<'EOF'
deb http://download.proxmox.com/debian/pve trixie pve-no-subscription
EOF
cat > /etc/apt/sources.list <<'EOF'
deb http://deb.debian.org/debian trixie main contrib non-free-firmware
deb http://deb.debian.org/debian trixie-updates main contrib non-free-firmware
deb http://security.debian.org/debian-security trixie-security main contrib non-free-firmware
EOF
{% endraw %}
{% else %}
log "Phase 1: Enterprise-Repos beibehalten (Subscription aktiv)"
{% endif %}

# =============================================================================
# Phase 2: System haerten - SSH + sysctl (nur Disk - kein Netzwerk noetig)
# =============================================================================
{% raw %}
log "Phase 2: SSH haerten"
declare -A SSH_OPTS=(
{% endraw %}
  ["PermitRootLogin"]="{{ pve_ssh_permit_root_login | default('prohibit-password') }}"
  ["PasswordAuthentication"]="{{ pve_ssh_password_auth | default('no') }}"
{% raw %}
  ["X11Forwarding"]="no"
  ["MaxAuthTries"]="3"
  ["LoginGraceTime"]="30"
)
for key in "${!SSH_OPTS[@]}"; do
    val="${SSH_OPTS[$key]}"
    if grep -qE "^#?${key}" /etc/ssh/sshd_config; then
        sed -i "s|^#\?${key}.*|${key} ${val}|" /etc/ssh/sshd_config
    else
        echo "${key} ${val}" >> /etc/ssh/sshd_config
    fi
done
systemctl restart ssh

log "Phase 2: sysctl haerten"
cat > /etc/sysctl.d/99-pve.conf <<'EOF'
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1
net.ipv4.tcp_syncookies = 1
kernel.kptr_restrict = 2
kernel.dmesg_restrict = 1
EOF
sysctl --system >/dev/null 2>&1
{% endraw %}

# =============================================================================
# Phase 3: Management-Bond (bond0 + vmbr0) via MAC-Adressen aufbauen
#
# bond0-MACs (zur Render-Zeit aus host_vars aufgeloest):
{% set bond0_nics = pve_nic_aliases | selectattr('role', 'equalto', 'bond0') | list %}
{% if bond0_nics | length == 0 %}
# GUARD: Kein bond0-Eintrag in pve_nic_aliases!
{% else %}{% for nic in bond0_nics %}
#   {{ nic.alias }}: {{ nic.mac }}
{% endfor %}{% endif %}
# =============================================================================
log "Phase 3: Management-Bond bond0 + vmbr0 aufbauen"

{% if bond0_nics | length == 0 %}
fail "FATAL: pve_nic_aliases enthaelt keine bond0-Eintraege fuer {{ _node_name }}!"
{% endif %}

# -- 3a: MAC -> Interfacename Lookup ------------------------------------------
{% raw %}
declare -A MAC_TO_IFACE=()
for iface_path in /sys/class/net/*/address; do
    iface=$(basename "$(dirname "$iface_path")")
    mac=$(cat "$iface_path" 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)
    [[ "$mac" == "00:00:00:00:00:00" ]] && continue
    [[ "$mac" == "" ]]                   && continue
    [[ "$iface" == "lo" ]]               && continue
    MAC_TO_IFACE["$mac"]="$iface"
done
log "Gefundene physische Interfaces:"
for mac in "${!MAC_TO_IFACE[@]}"; do
    log "  ${MAC_TO_IFACE[$mac]} -> $mac"
done
{% endraw %}

# -- 3b: Konfigurierte bond0-MACs aufloesen -----------------------------------
{% raw %}
BOND0_SLAVES=()
BOND0_ALIASES=()
{% endraw %}
{% for nic in bond0_nics %}
MAC_LOWER_{{ loop.index }}=$(echo "{{ nic.mac }}" | tr '[:upper:]' '[:lower:]')
if [[ -n "${MAC_TO_IFACE[$MAC_LOWER_{{ loop.index }}]:-}" ]]; then
    IFACE_{{ loop.index }}="${MAC_TO_IFACE[$MAC_LOWER_{{ loop.index }}]}"
    log "  OK: {{ nic.alias }} ({{ nic.mac }}) -> ${IFACE_{{ loop.index }}}"
    BOND0_SLAVES+=("${IFACE_{{ loop.index }}}")
    BOND0_ALIASES+=("{{ nic.alias }}")
else
    warn "MAC {{ nic.mac }} ({{ nic.alias }}) nicht gefunden!"
{% raw %}    log "  Verfuegbare MACs: ${!MAC_TO_IFACE[*]}"{% endraw %}

fi
{% endfor %}
{% raw %}
if [[ ${#BOND0_SLAVES[@]} -lt 1 ]]; then
    warn "Keine bond0-NIC gefunden! Konfigurierte MACs nicht auf diesem System."
    warn "Netzwerk-Konfiguration wird NICHT geschrieben. Phase 4+5 laufen weiter."
    BOND_SETUP_FAILED=1
else
    BOND_SETUP_FAILED=0
    log "bond0 Slaves: ${BOND0_SLAVES[*]}"
fi
{% endraw %}

# -- 3c: Persistente udev-Regeln fuer bond0-Slaves ----------------------------
{% raw %}
if [[ "${BOND_SETUP_FAILED}" -eq 0 ]]; then
log "udev-Regeln schreiben: /etc/udev/rules.d/70-pve-nic-aliases.rules"
mkdir -p /etc/udev/rules.d
UDEV_RULES_FILE="/etc/udev/rules.d/70-pve-nic-aliases.rules"
cat > "$UDEV_RULES_FILE" <<'UDEV_HEADER'
# Autogeneriert durch PVE firstboot.sh - NICHT manuell bearbeiten!
UDEV_HEADER
{% endraw %}
{% for nic in bond0_nics %}
MAC_FOR_UDEV_{{ loop.index }}=$(echo "{{ nic.mac }}" | tr '[:upper:]' '[:lower:]')
CURRENT_IFACE_{{ loop.index }}="${MAC_TO_IFACE[$MAC_FOR_UDEV_{{ loop.index }}]:-}"
if [[ -n "${CURRENT_IFACE_{{ loop.index }}}" ]]; then
    echo "SUBSYSTEM==\"net\", ACTION==\"add\", ATTR{address}==\"${MAC_FOR_UDEV_{{ loop.index }}}\", NAME=\"${CURRENT_IFACE_{{ loop.index }}}\"" >> "$UDEV_RULES_FILE"
fi
{% endfor %}
{% raw %}
udevadm control --reload-rules
log "udev-Regeln geschrieben und neu geladen"
fi  # end BOND_SETUP_FAILED check
{% endraw %}

# -- 3d: /etc/network/interfaces.d/bond0-vmbr0 schreiben ----------------------
{% raw %}
if [[ "${BOND_SETUP_FAILED}" -eq 0 ]]; then
log "Netzwerkkonfiguration schreiben: /etc/network/interfaces.d/bond0-vmbr0"
mkdir -p /etc/network/interfaces.d
grep -q 'source /etc/network/interfaces.d/\*' /etc/network/interfaces || \
    echo 'source /etc/network/interfaces.d/*' >> /etc/network/interfaces
DHCP_IFACE=$(awk '/^iface .* inet dhcp/{print $2; exit}' /etc/network/interfaces || true)
log "Vom Installer angelegte DHCP-Schnittstelle: ${DHCP_IFACE:-keine gefunden}"

write_interfaces_file() {
    local out="/etc/network/interfaces.d/bond0-vmbr0"
    {
        cat <<'HEADER'
# bond0 - Management + Corosync (LACP fast)
# Generiert durch PVE firstboot.sh - NICHT manuell bearbeiten!
HEADER
        for slave in "${BOND0_SLAVES[@]}"; do
            printf "auto %s\niface %s inet manual\n    bond-master bond0\n\n" \
                   "$slave" "$slave"
        done
        cat <<STATIC
auto bond0
iface bond0 inet manual
    bond-slaves     ${BOND0_SLAVES[*]}
    bond-mode       802.3ad
    bond-xmit-hash-policy layer3+4
    bond-lacp-rate  fast
    bond-miimon     100
{% endraw %}
    up ip link set bond0 mtu {{ pve_bond0_mtu | default(1500) }}
{% raw %}
auto vmbr0
iface vmbr0 inet static
{% endraw %}
    address  {{ pve_node_ip }}/{{ pve_node_cidr_prefix }}
    gateway  {{ pve_node_gw }}
    dns-nameservers {{ pve_node_dns }}
{% raw %}
    bridge-ports bond0
    bridge-stp   off
    bridge-fd    0
STATIC
    } > "$out"
    log "  Geschrieben: $out"
    log "  bond-slaves: ${BOND0_SLAVES[*]}"
}
write_interfaces_file

# -- 3e: DHCP-Interface deaktivieren -----------------------------------------
if [[ -n "${DHCP_IFACE:-}" ]]; then
    log "DHCP-Interface '${DHCP_IFACE}' deaktivieren"
    sed -i "/^auto ${DHCP_IFACE}$/s/^/# /" /etc/network/interfaces
    sed -i "/^iface ${DHCP_IFACE} inet dhcp/s/^/# /" /etc/network/interfaces
fi

# -- 3f: Bond + Bridge hochbringen --------------------------------------------
log "bond0-Slaves vorbereiten (flush + down)"
for slave in "${BOND0_SLAVES[@]}"; do
    ip addr flush dev "$slave" 2>/dev/null || true
    ip link set "$slave" down  2>/dev/null || true
done
log "bond0-Slaves, bond0 und vmbr0 hochbringen (ifup)"
for slave in "${BOND0_SLAVES[@]}"; do
    ifup "$slave" || warn "ifup $slave fehlgeschlagen"
done
ifup bond0  || warn "ifup bond0 fehlgeschlagen - LACP-Negotiation ggf. noch ausstehend"
ifup vmbr0  || warn "ifup vmbr0 fehlgeschlagen - Konfiguration ist geschrieben, nach Reboot aktiv"

log "Warte auf LACP-Negotiation (max 30s)"
BOND_UP=0
for i in $(seq 1 30); do
    if ip link show bond0 2>/dev/null | grep -q 'state UP'; then
        log "bond0 ist UP nach ${i}s"
        BOND_UP=1
        break
    fi
    sleep 1
done
[[ "${BOND_UP}" -eq 0 ]] && warn "bond0 nach 30s noch nicht UP - Switch-LACP pruefen!"

{% endraw %}
if ping -c 2 -W 2 "{{ pve_node_gw }}" >/dev/null 2>&1; then
    log "Gateway {{ pve_node_gw }} erreichbar - Netzwerk OK"
else
    warn "Gateway {{ pve_node_gw }} nicht erreichbar."
{% raw %}    log "  Bond0-Status: $(cat /proc/net/bonding/bond0 2>/dev/null | grep 'MII Status' | head -2)"{% endraw %}

fi
{% raw %}
else
    warn "=== Phase 3 uebersprungen (keine NICs gefunden) - Netzwerk manuell konfigurieren! ==="
fi  # end BOND_SETUP_FAILED check

{% endraw %}
log "=== Phase 3 abgeschlossen: bond0/vmbr0 auf {{ pve_node_ip }}/{{ pve_node_cidr_prefix }} ==="

# =============================================================================
# Phase 4: APT update + Pakete installieren
# =============================================================================
{% raw %}
log "Phase 4: Basis-Pakete installieren"
wait_for_apt
DEBIAN_FRONTEND=noninteractive apt-get update -qq
DEBIAN_FRONTEND=noninteractive apt-get install -y \
    ifenslave \
    ethtool \
{% endraw %}
    {{ (pve_extra_packages | default(['lldpd'])) | join(' \\\n    ') }}

# =============================================================================
# Phase 5: Post-Network-Tasks
# =============================================================================
{% if lldpd_configure | default(true) %}
{% raw %}
log "Phase 5: lldpd konfigurieren"
mkdir -p /etc/lldpd.d
cat > /etc/lldpd.d/00-proxmox.conf <<'EOF'
{% endraw %}
configure lldp portidsubtype {{ lldpd_port_id_subtype | default('macaddress') }}
configure system description "{{ lldpd_system_description | default('Proxmox VE Node') }}"
configure system platform "Proxmox VE"
configure lldp tx-interval 30
EOF
{% raw %}
systemctl enable --now lldpd
{% endraw %}
{% endif %}

{% if pve_ntp_servers | default([]) | length > 0 %}
{% raw %}
log "Phase 5: NTP konfigurieren"
cat > /etc/systemd/timesyncd.conf <<'EOF'
[Time]
{% endraw %}
NTP={{ pve_ntp_servers | join(' ') }}
FallbackNTP=pool.ntp.org
EOF
{% raw %}
systemctl restart systemd-timesyncd && timedatectl set-ntp true
{% endraw %}
{% endif %}

{% if not pve_use_subscription %}
{% raw %}
log "Phase 5: Subscription-Warnung deaktivieren"
PVEUI="/usr/share/javascript/proxmox-widget-toolkit/proxmoxlib.js"
[ -f "$PVEUI" ] && cp "$PVEUI" "${PVEUI}.bak" && \
    sed -i "s/Ext.Msg.show({/void({/g" "$PVEUI" 2>/dev/null || true
{% endraw %}
{% endif %}

log "=== Ansible kann den Node jetzt unter {{ pve_node_ip }} erreichen ==="
log "=== First-Boot vollstaendig abgeschlossen ==="
{% raw %}
touch /var/lib/pve-firstboot-done
{% endraw %}
